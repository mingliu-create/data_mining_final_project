# ── 虛擬環境 ──────────────────────────────────────────────────────────────────
.venv/

# ── Python 編譯產物 ────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# ── 原始資料（體積龐大，不進版控）─────────────────────────────────────────────
raw_data/

# ── 參考資料（同學的程式碼，僅供本地參考）─────────────────────────────────────
tmp/

# ── 前處理產出（可從原始資料重新產生）──────────────────────────────────────────
Training_Testing_Data/
Stability/
OSM/
Predictions/
Animations/
ckpt/

# ── 生成資料檔（大型 CSV，可重跑產生）──────────────────────────────────────────
data/grid_poi_features.csv
data/user_stability_features.csv

# ── 模型 checkpoint（體積大，另外管理）────────────────────────────────────────
models/checkpoints/
*.pt
*.pth

# ── 評估報告（可重跑產生）──────────────────────────────────────────────────────
eval/reports/

# ── 圖表輸出（可重跑產生）──────────────────────────────────────────────────────
output/

# ── Claude Code 記憶資料夾 ─────────────────────────────────────────────────────
.claude/

# ── 系統 / IDE 雜項 ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
